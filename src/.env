# ----------------------
# General environment
# ----------------------
ASPNETCORE_ENVIRONMENT=Development
APPDATA=/path/to/appdata          # Path to user secrets folder
USERPROFILE=/path/to/userprofile  # Path to HTTPS certificates

# ----------------------
# Service ports
# ----------------------
CATALOGDB_PORT=1434
SHOPPINGCARTDB_PORT=5433
ORDERDB_PORT=1435
IDENTITYDB_PORT=1436

CATALOG_API_PORT=7000
CATALOG_API_HTTPS_PORT=7070
SHOPPINGCART_API_PORT=7001
SHOPPINGCART_API_HTTPS_PORT=7071
ORDERING_API_PORT=7002
ORDERING_API_HTTPS_PORT=7072
API_GATEWAY_PORT=7005
API_GATEWAY_HTTPS_PORT=7075
AUTH_API_PORT=7007
AUTH_API_HTTPS_PORT=7077
REDIS_PORT=6379
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ----------------------
# Database credentials
# ----------------------
CATALOGDB_SA_PASSWORD=MyPass123
SHOPPINGCARTDB_USER=postgres
SHOPPINGCARTDB_PASSWORD=postgres
SHOPPINGCARTDB_NAME=ShoppingCartDb
ORDERDB_SA_PASSWORD=MyPass123
IDENTITYDB_SA_PASSWORD=MyPass123

# ----------------------
# ASP.NET URLs
# ----------------------
CATALOG_API_URL=http://+:80
SHOPPINGCART_API_URL=http://+:80
ORDERING_API_URL=http://+:80
API_GATEWAY_URL=http://+:80
AUTH_API_URL=http://+:80

# ----------------------
# Feature flags
# ----------------------
FEATURE_ORDER_FULLFILMENT=false

# ----------------------
# Connection strings
# ----------------------
CONN_CATALOG_DB=Server=catalogdb;Database=CoffeeShop_Catalog;User=sa;Password=${CATALOGDB_SA_PASSWORD};Encrypt=False;TrustServerCertificate=True
CONN_SHOPPINGCART_DB=Host=shoppingCartdb;Port=${SHOPPINGCARTDB_PORT};Database=${SHOPPINGCARTDB_NAME};Username=${SHOPPINGCARTDB_USER};Password=${SHOPPINGCARTDB_PASSWORD}
CONN_ORDER_DB=Server=orderdb;Database=CoffeeShop_Order;User Id=sa;Password=${ORDERDB_SA_PASSWORD};Encrypt=False;TrustServerCertificate=True
CONN_IDENTITY_DB=Server=identitydb;Database=CoffeeShop_Identity;User Id=sa;Password=${IDENTITYDB_SA_PASSWORD};Encrypt=False;TrustServerCertificate=True
CONN_REDIS=distributedcache:${REDIS_PORT}

# ----------------------
# RabbitMQ settings
# ----------------------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq://ecommerce-mq:${RABBITMQ_AMQP_PORT}

# ----------------------
# API Gateway ReverseProxy cluster addresses
# ----------------------
REVERSEPROXY_CATALOG=http://catalog-api:80
REVERSEPROXY_SHOPPINGCART=http://shopping-cart-api:80
REVERSEPROXY_ORDERING=http://ordering-api:80
REVERSEPROXY_AUTH=http://auth-api:80

# ----------------------
# API Gateway
# ----------------------
API_GATEWAY_ADDRESS=http://api-gateway:80